# Backend environment variables for Flask
# ⚠️ NEVER commit real secrets. Set production values in hosting platform (Render, etc.)

# Environment mode
FLASK_ENV=production

# Security secrets (generate with: python -c "import secrets; print(secrets.token_hex(32))")
SECRET_KEY=replace-with-a-secure-secret-key
JWT_SECRET_KEY=replace-with-a-secure-jwt-secret

# Database (Render provides /tmp for SQLite; use managed PostgreSQL for production)
DATABASE_URL=sqlite:////tmp/techquiz.db

# Server
PORT=5000

# CORS origins (comma-separated; frontend will be verified by CORS handler)
# Localhost for development, Vercel for production
CORS_ORIGINS=http://localhost:3001,http://127.0.0.1:3001

# Optional JWT settings
# JWT_ACCESS_TOKEN_EXPIRES=3600
# JWT_REFRESH_TOKEN_EXPIRES=86400
